---
interface Props {
  title?: string;
  description?: string;
  primaryText?: string;
  primaryLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
}

const {
  title = "Mehr Projekte entdecken",
  description = "Schau dir weitere Case Studies an oder nimm direkt Kontakt auf.",
  primaryText = "Alle Projekte",
  primaryLink = "/projects",
  secondaryText = "Kontakt aufnehmen",
  secondaryLink = "/contact"
} = Astro.props;
---

<section class="section--tight cta-section">
  <div class="cta-band">
    <h2>{title}</h2>
    <p>{description}</p>
    <div class="hero__ctas">
      <a class="btn btn-primary" href={primaryLink}>{primaryText}</a>
      <a class="btn btn-outline" href={secondaryLink}>{secondaryText}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
  }
  .cta-band {
    text-align: center;
    background: var(--card-bg, #ffffff);
    border: 1px solid var(--border);
    border-radius: var(--radius-l);
    padding: var(--space-5) var(--space-4);
    box-shadow: var(--shadow-soft);
  }
  .cta-band h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.6rem;
    font-family: var(--font-display);
  }
  .cta-band p {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto 1.5rem;
  }
  .hero__ctas {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
  }
  @media (max-width: 480px) {
    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>
