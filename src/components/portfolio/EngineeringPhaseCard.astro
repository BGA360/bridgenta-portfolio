---
interface Props {
  image: string;
  title: string;
  description: string;
}

const { image, title, description } = Astro.props;
---

<div class="phase-card">
  <div class="phase-card__image-wrapper">
    <img 
      src={image} 
      alt={`${title}: ${description}`} 
      class="phase-card__image" 
      loading="lazy"
      width="800"
      height="450"
    />
  </div>
  <div class="phase-card__content">
    <h3 class="phase-card__title">{title}</h3>
    <p class="phase-card__description">{description}</p>
  </div>
</div>

<style>
  .phase-card {
    background: var(--card-bg, #ffffff);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    overflow: hidden;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-soft);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.25s ease;
  }
  .phase-card:hover {
    transform: translateY(-2px);
    border-color: rgba(194, 24, 91, 0.3);
  }
  .phase-card__image-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #fdfdfd;
    border-bottom: 1px solid var(--border);
  }
  .phase-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .phase-card:hover .phase-card__image {
    transform: scale(1.02);
  }
  .phase-card__content {
    padding: 1.25rem 1.5rem;
  }
  .phase-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 0.4rem 0;
  }
  .phase-card__description {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
