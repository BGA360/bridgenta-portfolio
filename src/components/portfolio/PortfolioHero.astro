---
interface Props {
  title: string;
  subtitle?: string;
  status: string;
  heroImage?: string;
  initials: string;
  badgeClass: string;
}

const { title, subtitle, status, heroImage, initials, badgeClass } = Astro.props;
---

<div class="portfolio-hero-container">
  {heroImage ? (
    <div class="hero-banner hero-banner--image">
      <img 
        src={heroImage} 
        alt={title} 
        width="1672" 
        height="941" 
        style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;"
        loading="eager"
      />
    </div>
  ) : (
    <div class="hero-banner"><span>{initials}</span></div>
  )}

  <span class={`badge ${badgeClass}`}>{status}</span>
  <h1 class="portfolio-title">{title}</h1>
  {subtitle && <p class="lede portfolio-subtitle">{subtitle}</p>}
</div>

<style>
  .portfolio-hero-container {
    margin-bottom: var(--space-4);
  }
  .portfolio-title {
    margin-top: 0.9rem;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
    font-weight: 800;
  }
  .portfolio-subtitle {
    margin-top: 0.6rem;
    font-size: 1.25rem;
    color: var(--text-muted);
  }
  .hero-banner--image {
    background: none !important;
  }
  .hero-banner--image::after {
    display: none !important;
  }
</style>
