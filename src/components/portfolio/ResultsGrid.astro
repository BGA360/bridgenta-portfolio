---
interface ResultItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  results: ResultItem[];
}

const { results } = Astro.props;

// A helper helper to return the matching SVG path/icon
const getIconSvg = (iconName?: string) => {
  const name = iconName?.toLowerCase() || 'check';
  if (name === 'shield' || name === 'security' || name === 'sicherheit') {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="result-icon-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;
  }
  if (name === 'tool' || name === 'maintenance' || name === 'wartbarkeit' || name === 'engineering') {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="result-icon-svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`;
  }
  if (name === 'star' || name === 'conversion' || name === 'chart' || name === 'performance' || name === 'speed') {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="result-icon-svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
  }
  // Default checkmark
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="result-icon-svg"><polyline points="20 6 9 17 4 12"/></svg>`;
};
---

<div class="results-grid">
  {results.map((item) => (
    <div class="result-card">
      <div class="result-card__icon-wrapper" set:html={getIconSvg(item.icon)} />
      <div class="result-card__content">
        <h3 class="result-card__title">{item.title}</h3>
        <p class="result-card__description">{item.description}</p>
      </div>
    </div>
  ))}
</div>

<style is:global>
  .result-icon-svg {
    width: 20px;
    height: 20px;
    color: var(--magenta);
  }
</style>

<style>
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-3);
    margin-top: 1.5rem;
  }
  .result-card {
    background: var(--card-bg, #ffffff);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    box-shadow: var(--shadow-soft);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .result-card:hover {
    transform: translateY(-2px);
    border-color: rgba(194, 24, 91, 0.25);
    box-shadow: var(--shadow-lift);
  }
  .result-card__icon-wrapper {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(194, 24, 91, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .result-card__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .result-card__title {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 0.4rem 0;
    font-family: var(--font-display);
    line-height: 1.3;
  }
  .result-card__description {
    font-size: 0.94rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
