---
import Schema from '../components/Schema.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  project?: {
    title: string;
    category: string;
    status: string;
    technologies: string;
    description: string;
  };
}

const { title, description = "Portfolio von Frank Duru – Web Development, AI-assisted Development und SEO/AEO/GEO.", project } = Astro.props;

// Fetch projects dynamically for footer listing
const allProjects = await getCollection('projects');

// Determine current path for navigation active states
const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/\/$/, ""); // Normalize path (remove trailing slash)

// Normalize URL for production canonical representation
const siteUrl = 'https://bridgenta.de';
let cleanPathname = pathname.replace(/\/$/, "").replace(/\/index\.html$/, "");
if (cleanPathname === "/index") {
  cleanPathname = "";
}
const canonical = `${siteUrl}${cleanPathname}`;

// Format title consistently for SEO
const displayTitle = title === "Startseite" 
  ? "Frank Duru – Web Developer & AI Software Engineer | BridGenta.de"
  : `${title} – BridGenta.de | Frank Duru`;

import '../styles/styles.css';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>{displayTitle}</title>
  <meta name="description" content={description}>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#C2185B">
  
  <!-- Preload Critical Fonts to prevent layout shifts -->
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/fraunces-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  
  <!-- Canonical Link Tag -->
  <link rel="canonical" href={canonical} />

  <!-- Crawler Indexing Directives -->
  <meta name="robots" content="index, follow" />

  <!-- Regional & Language Targeting (hreflang) -->
  <link rel="alternate" hreflang="de" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  <!-- Open Graph & Twitter Cards -->
  <meta property="og:title" content={displayTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://bridgenta.de/images/og-featured.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={displayTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://bridgenta.de/images/og-featured.jpg" />

  <!-- GEO Metadata Tags -->
  <meta name="geo.region" content="DE-HE" />
  <meta name="geo.position" content="50.1109;8.6821" />
  <meta name="ICBM" content="50.1109, 8.6821" />
  <meta name="geo.placename" content="Frankfurt am Main, Hessen, Deutschland" />

  <!-- JSON-LD Schema Graph -->
  <Schema title={title} description={description} project={project} />

  <link rel="manifest" href="/manifest.json">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <a class="skip-link" href="#main">Zum Inhalt springen</a>

  <div class="nav-wrap">
    <nav class="nav" aria-label="Hauptnavigation">
      <a class="nav__logo" href="/">
        <svg class="logo-mark" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="8" cy="8" r="4" fill="url(#logo-grad-layout)"/>
          <circle cx="20" cy="8" r="4" fill="url(#logo-grad-layout)"/>
          <circle cx="14" cy="20" r="4" fill="url(#logo-grad-layout)"/>
          <path d="M8 8 L14 20 L20 8" stroke="url(#logo-grad-layout)" stroke-width="2"/>
          <defs>
            <linearGradient id="logo-grad-layout" x1="8" y1="8" x2="20" y2="20" gradientUnits="userSpaceOnUse">
              <stop stop-color="#C2185B"/>
              <stop offset="1" stop-color="#7B1E57"/>
            </linearGradient>
          </defs>
        </svg>
        Brid<span>Genta</span>.de
      </a>
      <ul class="nav__links">
        <li><a href="/" aria-current={cleanPath === "" || cleanPath === "/index.html" ? "page" : undefined}>Startseite</a></li>
        <li><a href="/projects" aria-current={cleanPath.startsWith("/projects") || cleanPath.startsWith("/project-") ? "page" : undefined}>Projekte</a></li>
        <li><a href="/#faehigkeiten" id="nav-link-faehigkeiten">Fähigkeiten</a></li>
        <li><a href="/about" aria-current={cleanPath === "/about" ? "page" : undefined}>Über mich</a></li>
        <li><a href="/contact" aria-current={cleanPath === "/contact" ? "page" : undefined}>Kontakt</a></li>
      </ul>
      <div class="nav__cta">
        <a class="btn-nav-cta" href="/contact">
          Kontakt aufnehmen
          <span class="icon-circle">
            <svg viewBox="0 0 24 24" width="12" height="12">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </span>
        </a>
      </div>
      <div class="nav__actions">
        <button class="nav__toggle" aria-label="Menü öffnen" aria-expanded="false">
          <span></span>
        </button>
      </div>
    </nav>
  </div>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <!-- Footer Top Tier: Quick-Contact Info Cards -->
      <div class="footer-top-tier">
        <div class="footer-info-grid">
          <div class="footer-info-card">
            <div class="icon-tile" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div>
              <h4>Verfügbarkeit</h4>
              <p>Offen für neue berufliche Chancen</p>
            </div>
          </div>
          <div class="footer-info-card">
            <div class="icon-tile" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <h4>E-Mail</h4>
              <p>ref@bridgenta.de</p>
            </div>
          </div>
          <div class="footer-info-card">
            <div class="icon-tile" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <h4>Standort</h4>
              <p>Deutschland (Remote / Frankfurt-nah)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer Bottom Tier -->
      <div class="footer-grid">
        <div class="footer-brand">
          <a class="nav__logo" href="/">
            <svg class="logo-mark" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="8" cy="8" r="4" fill="url(#logo-grad-footer-layout)"/>
              <circle cx="20" cy="8" r="4" fill="url(#logo-grad-footer-layout)"/>
              <circle cx="14" cy="20" r="4" fill="url(#logo-grad-footer-layout)"/>
              <path d="M8 8 L14 20 L20 8" stroke="url(#logo-grad-footer-layout)" stroke-width="2"/>
              <defs>
                <linearGradient id="logo-grad-footer-layout" x1="8" y1="8" x2="20" y2="20" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#C2185B"/>
                  <stop offset="1" stop-color="#7B1E57"/>
                </linearGradient>
              </defs>
            </svg>
            Brid<span>Genta</span>.de
          </a>
          <p>Portfolio von Frank Duru – Web-Entwicklung, IT-Sicherheit, Systemadministration und Suchmaschinenoptimierung.</p>
        </div>
        <div class="footer-col">
          <h4>Navigation</h4>
          <ul>
            <li><a href="/">Startseite</a></li>
            <li><a href="/projects">Projekte</a></li>
            <li><a href="/#faehigkeiten">Fähigkeiten</a></li>
            <li><a href="/about">Über mich</a></li>
            <li><a href="/contact">Kontakt</a></li>
            <li><a href="/impressum">Impressum</a></li>
            <li><a href="/datenschutz">Datenschutz</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Projekte</h4>
          <ul>
            {allProjects.map((proj) => (
              <li><a href={`/project-${proj.slug}`}>{proj.data.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <h4>Newsletter</h4>
          <p style="font-size:0.88rem; margin-bottom: 0.5rem; color: rgba(255,255,255,0.5);">Erhalten Sie Updates zu neuen Projekten.</p>
          <form class="newsletter-form" aria-label="Newsletter-Anmeldung (Demo)">
            <input type="email" placeholder="deine@email.de" required>
            <button type="submit" aria-label="Senden">
              <svg viewBox="0 0 24 24" width="12" height="12"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </form>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="copyright-badge">
          <span>© <span id="year">2026</span> BridGenta.de – Frank Duru</span>
          <span>E-Mail: ref@bridgenta.de</span>
        </div>
      </div>
    </div>
  </footer>

  <script src="../scripts/script.js"></script>
</body>
</html>
