---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch all project markdown files
const projects = await getCollection('projects');
const primarySlugs = ['bridgenta', 'aeocortex', 'luminapraxisds', 'rootedrealitygarden', 'starcleaners'];

// Only show active portfolio projects, sorted in specified order
const sortedProjects = projects
  .filter((p) => primarySlugs.includes(p.slug))
  .sort((a, b) => primarySlugs.indexOf(a.slug) - primarySlugs.indexOf(b.slug));

// Generate 2-letter initials for each project card
const getInitials = (title) => {
  if (title === 'FD-ESS') return 'FD';
  const clean = title.replace(/[^a-zA-Z]/g, '');
  if (clean.length >= 2) {
    const uppers = clean.split('').filter(c => c === c.toUpperCase() && c !== c.toLowerCase());
    if (uppers.length >= 2) return uppers.slice(0, 2).join('');
    return clean.slice(0, 2).toUpperCase();
  }
  return title.slice(0, 2).toUpperCase();
};

// Generate badge class matching status
const getBadgeClass = (status) => {
  if (status === 'In Entwicklung') return 'badge--dev';
  if (status === 'Private Beta') return 'badge--beta';
  if (status === 'Konzept / Aufbau') return 'badge--concept';
  if (status === 'Abgeschlossen') return 'badge--done';
  return 'badge--dev';
};
---

<Layout title="Projekte" description="Übersicht meiner Portfolio-Projekte. Detaillierte Case Studies zu Web-Entwicklung, AI-gestützten Softwareprojekten, technischem SEO und Antwortmaschinen-Optimierung.">
  <section class="page-hero">
    <div class="page-hero__inner">
      <span class="eyebrow">Projekte</span>
      <h1 style="margin-top:0.9rem;">Projektkatalog</h1>
      <p class="lede">Fallstudien und Softwareprojekte mit Fokus auf optimierte Suchmaschinenpräsenzen, strukturierte Web-Entwicklung und zuverlässige Webmaster-Betreuung.</p>
    </div>
  </section>

  <div class="floating-card-overlap">
    <div class="breadcrumb-card">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a><span class="sep">/</span><span>Projekte</span>
      </nav>
    </div>
  </div>

  <section class="section" data-reveal>
    <div class="container">
      <div class="grid grid--2">

        {sortedProjects.map((project) => {
          const initials = getInitials(project.data.title);
          const badgeClass = getBadgeClass(project.data.status);
          const techList = project.data.technologies.split(',').map(t => t.trim());

          return (
            <article class="project-card">
              <div class="project-card__media">
                {project.slug === 'bridgenta' ? (
                  <img src="/images/bga-portfolio/BG-PA00-Card.webp" alt="BridGenta project overview showing the public presentation of the legacy application reconstruction platform." loading="lazy" width="1672" height="941" style="width: 100%; height: 100%; object-fit: cover;" />
                ) : (
                  <span>{initials}</span>
                )}
              </div>
              <div class="project-card__top">
                <span class="project-card__cat">{project.data.category}</span>
                <span class={`badge ${badgeClass}`}>{project.data.status}</span>
              </div>
              <h3>{project.data.title}</h3>
              <p>{project.data.description}</p>
              <div class="project-card__tech">
                {techList.map((tech) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
              <div class="project-card__footer">
                <a class="btn btn-secondary btn-block" href={`/project-${project.slug}`}>Case Study ansehen</a>
              </div>
            </article>
          );
        })}

        <article class="project-card">
          <div class="project-card__media"><span>WM</span></div>
          <div class="project-card__top">
            <span class="project-card__cat">WordPress / SEO / CMS</span>
            <span class="badge badge--exp">Erfahrung</span>
          </div>
          <h3>Webmaster Projects</h3>
          <p>Langjährige Erfahrung seit 2009 mit Webseiten, CMS, Hosting, SEO, E-Commerce und technischen Webprojekten.</p>
          <div class="project-card__tech">
            <span class="tag">WordPress</span><span class="tag">Elementor</span><span class="tag">Technical SEO</span><span class="tag">Hosting</span>
          </div>
          <div class="project-card__footer">
            <a class="btn btn-secondary btn-block" href="/about">Mehr erfahren</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <section class="section--tight" data-reveal>
    <div class="cta-band">
      <h2>Fragen zu einem Projekt?</h2>
      <p>Ich erkläre gerne Hintergrund, Entscheidungen und technische Umsetzung jedes Projekts im Gespräch mit Recruitern und Unternehmen.</p>
      <div class="hero__ctas">
        <a class="btn btn-primary" href="/contact">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Layout>
