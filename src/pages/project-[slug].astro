---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PortfolioHero from '../components/portfolio/PortfolioHero.astro';
import PortfolioSidebar from '../components/portfolio/PortfolioSidebar.astro';
import PortfolioSection from '../components/portfolio/PortfolioSection.astro';
import EngineeringPhaseCard from '../components/portfolio/EngineeringPhaseCard.astro';
import ResultsGrid from '../components/portfolio/ResultsGrid.astro';
import RelatedProjects from '../components/portfolio/RelatedProjects.astro';
import ProjectCTA from '../components/portfolio/ProjectCTA.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const activeProjectSlugs = ['bridgenta', 'aeocortex', 'luminapraxisds', 'rootedrealitygarden', 'starcleaners'];
  const activeProjects = projects.filter((entry) => activeProjectSlugs.includes(entry.slug));
  return activeProjects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Query projects collection to compute prev/next navigation links
const activeProjectSlugs = ['bridgenta', 'aeocortex', 'luminapraxisds', 'rootedrealitygarden', 'starcleaners'];
const projects = (await getCollection('projects'))
  .filter((p) => activeProjectSlugs.includes(p.slug))
  .sort((a, b) => activeProjectSlugs.indexOf(a.slug) - activeProjectSlugs.indexOf(b.slug));
const currentIndex = projects.findIndex((p) => p.slug === entry.slug);
const prevProject = projects[(currentIndex - 1 + projects.length) % projects.length];
const nextProject = projects[(currentIndex + 1) % projects.length];

// Generate the 2-letter initials for the fallback banner
const getInitials = (title) => {
  if (title === 'FD-ESS') return 'FD';
  const clean = title.replace(/[^a-zA-Z]/g, '');
  if (clean.length >= 2) {
    const uppers = clean.split('').filter(c => c === c.toUpperCase() && c !== c.toLowerCase());
    if (uppers.length >= 2) return uppers.slice(0, 2).join('');
    return clean.slice(0, 2).toUpperCase();
  }
  return title.slice(0, 2).toUpperCase();
};

const initials = getInitials(entry.data.title);

// Get the corresponding badge class based on status
const getBadgeClass = (status) => {
  if (status === 'In Entwicklung') return 'badge--dev';
  if (status === 'Private Beta') return 'badge--beta';
  if (status === 'Konzept / Aufbau') return 'badge--concept';
  if (status === 'Abgeschlossen') return 'badge--done';
  return 'badge--dev';
};

const badgeClass = getBadgeClass(entry.data.status);

// Set section titles with frontmatter overrides
const sectionTitles = {
  overview: entry.data.sectionTitles?.overview || "Project Overview",
  problem: entry.data.sectionTitles?.problem || "Problem to Solve",
  approach: entry.data.sectionTitles?.approach || "Engineering Approach",
  action: entry.data.sectionTitles?.action || "Reconstruction in Action",
  results: entry.data.sectionTitles?.results || "Results",
  takeaways: entry.data.sectionTitles?.takeaways || "Key Takeaways",
};

// Set hero image for BridGenta
const heroImage = entry.slug === 'bridgenta' ? '/images/bga-portfolio/BG-PA01-Hero.webp' : undefined;
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  project={{
    title: entry.data.title,
    category: entry.data.category,
    status: entry.data.status,
    technologies: entry.data.technologies,
    description: entry.data.description
  }}
>
  <section class="section section--tight">
    <div class="container">
      <!-- Breadcrumb navigation -->
      <div class="breadcrumb-card" style="margin-bottom: var(--space-4);">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Startseite</a><span class="sep">/</span>
          <a href="/projects">Projekte</a><span class="sep">/</span>
          <span>{entry.data.title}</span>
        </nav>
      </div>

      <!-- Hero Header -->
      <PortfolioHero 
        title={entry.data.title}
        subtitle={entry.data.subtitle || entry.data.category}
        status={entry.data.status}
        heroImage={heroImage}
        initials={initials}
        badgeClass={badgeClass}
      />

      <!-- Notice for private beta / test phases -->
      {entry.data.notice && (
        <div class="notice">
          <h4>Hinweis zur privaten Beta</h4>
          <p>{entry.data.notice}</p>
        </div>
      )}

      <!-- Main content and Sidebar Grid -->
      <div class="detail-grid" style="margin-top: var(--space-5);">
        <div class="tina-content">
          <Content />

          <a class="btn btn-secondary" href="/projects" style="margin-top: 2.5rem; display: inline-block;">
            ← Zurück zu allen Projekten
          </a>
        </div>

        <!-- Sticky Sidebar -->
        <PortfolioSidebar 
          category={entry.data.category}
          status={entry.data.status}
          timeline={entry.data.timeline}
          technologies={entry.data.technologies}
          devStack={entry.data.devStack}
          aiBuilders={entry.data.aiBuilders}
          role={entry.data.role}
        />
      </div>

      <!-- Prev/Next Navigation -->
      <RelatedProjects 
        prevProject={prevProject}
        nextProject={nextProject}
      />
    </div>
  </section>

  <!-- CTA section -->
  {entry.data.cta ? (
    <ProjectCTA 
      title={entry.data.cta.title}
      description={entry.data.cta.description}
      primaryText={entry.data.cta.primaryText}
      primaryLink={entry.data.cta.primaryLink}
      secondaryText={entry.data.cta.secondaryText}
      secondaryLink={entry.data.cta.secondaryLink}
    />
  ) : (
    <ProjectCTA />
  )}
</Layout>

<style is:global>
  /* Format compiled Markdown body to match legacy detail-block styles */
  .tina-content h2 {
    font-size: 1.45rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.8rem;
    color: var(--text-dark);
    font-family: var(--font-display);
    position: relative;
    padding-bottom: 0.4rem;
  }
  .tina-content h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background: var(--magenta);
  }
  .tina-content h2:first-of-type {
    margin-top: 0;
  }
  .tina-content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }
  .tina-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.2rem;
    color: var(--text-muted);
    line-height: 1.6;
    list-style-type: disc;
  }
  .tina-content li {
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }
  .tina-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-m);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
    box-shadow: var(--shadow-soft);
    display: block;
  }
  .tina-content figure {
    margin: 2rem 0;
  }
  .tina-content figcaption {
    font-size: 0.88rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 0.6rem;
  }
  .tina-content table {
    width: 100%;
    margin-bottom: 1.5rem;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .tina-content th,
  .tina-content td {
    padding: 0.75rem;
    border: 1px solid var(--border);
    text-align: left;
  }
  .tina-content th {
    background: rgba(0, 0, 0, 0.02);
    font-weight: 600;
  }

  .principles-list {
    margin-bottom: 1.5rem;
    padding-left: 0;
    list-style-type: none;
  }
  .principles-list li {
    margin-bottom: 0.8rem;
    font-size: 1.05rem;
    line-height: 1.6;
    position: relative;
    padding-left: 1.5rem;
    color: var(--text-muted);
  }
  .principles-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--magenta);
    font-weight: 700;
  }
  .artifacts-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const mermaidBlocks = document.querySelectorAll(".language-mermaid");
    if (mermaidBlocks.length > 0) {
      const script = document.createElement("script");
      script.src = "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js";
      script.onload = () => {
        mermaid.initialize({ startOnLoad: true, theme: 'neutral' });
        
        mermaidBlocks.forEach((block, index) => {
          const rawCode = block.textContent;
          const diagramContainer = document.createElement("div");
          diagramContainer.className = "mermaid";
          diagramContainer.id = `mermaid-${index}`;
          diagramContainer.textContent = rawCode;
          
          const preElement = block.closest("pre") || block;
          preElement.parentNode.replaceChild(diagramContainer, preElement);
        });
        
        mermaid.init(undefined, document.querySelectorAll(".mermaid"));
      };
      document.head.appendChild(script);
    }
  });
</script>
