---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Query projects collection to compute prev/next navigation links
const projects = await getCollection('projects');
const currentIndex = projects.findIndex((p) => p.slug === entry.slug);
const prevProject = projects[(currentIndex - 1 + projects.length) % projects.length];
const nextProject = projects[(currentIndex + 1) % projects.length];

// Generate the 2-letter initials for the hero banner
const getInitials = (title) => {
  if (title === 'FD-ESS') return 'FD';
  const clean = title.replace(/[^a-zA-Z]/g, '');
  if (clean.length >= 2) {
    const uppers = clean.split('').filter(c => c === c.toUpperCase() && c !== c.toLowerCase());
    if (uppers.length >= 2) return uppers.slice(0, 2).join('');
    return clean.slice(0, 2).toUpperCase();
  }
  return title.slice(0, 2).toUpperCase();
};

const initials = getInitials(entry.data.title);

// Get the corresponding badge class based on status
const getBadgeClass = (status) => {
  if (status === 'In Entwicklung') return 'badge--dev';
  if (status === 'Private Beta') return 'badge--beta';
  if (status === 'Konzept / Aufbau') return 'badge--concept';
  return 'badge--dev';
};

const badgeClass = getBadgeClass(entry.data.status);
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  project={{
    title: entry.data.title,
    category: entry.data.category,
    status: entry.data.status,
    technologies: entry.data.technologies,
    description: entry.data.description
  }}
>
  <section class="section section--tight">
    <div class="container">
      <div class="breadcrumb-card" style="margin-bottom: var(--space-3);">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Startseite</a><span class="sep">/</span>
          <a href="/projects">Projekte</a><span class="sep">/</span>
          <span>{entry.data.title}</span>
        </nav>
      </div>

      <div class="hero-banner"><span>{initials}</span></div>

      <span class={`badge ${badgeClass}`}>{entry.data.status}</span>
      <h1 style="margin-top:0.9rem; font-size:clamp(2rem,4vw,2.8rem);">{entry.data.title}</h1>
      <p class="lede" style="margin-top:0.6rem;">{entry.data.category}</p>

      {entry.data.notice && (
        <div class="notice">
          <h4>Hinweis zur privaten Beta</h4>
          <p>{entry.data.notice}</p>
        </div>
      )}

      <div class="detail-grid" style="margin-top:var(--space-5);">
        <div class="tina-content">
          <Content />

          <a class="btn btn-secondary" href="/projects" style="margin-top: 2.5rem; display: inline-block;">← Zurück zu allen Projekten</a>
        </div>

        <aside>
          <div class="card sidebar-card">
            <h3 style="font-size:1.05rem; margin-bottom:1rem;">Projektdetails</h3>
            <div class="meta-list">
              <div class="meta-row"><span class="k">Kategorie</span><span class="v">{entry.data.category}</span></div>
              <div class="meta-row"><span class="k">Status</span><span class="v">{entry.data.status}</span></div>
              <div class="meta-row"><span class="k">Technologien</span><span class="v">{entry.data.technologies}</span></div>
            </div>
            <a class="btn btn-primary btn-block" style="margin-top:1.4rem;" href="/contact">Über dieses Projekt sprechen</a>
          </div>
        </aside>
      </div>

      <!-- Projekt-Navigation (Vorheriges / Nächstes Projekt) -->
      <div class="project-navigation-wrap" data-reveal>
        <h3 class="nav-title">Weitere Case Studies</h3>
        <div class="project-nav-grid">
          <a href={`/project-${prevProject.slug}`} class="project-nav-link prev-link" aria-label={`Vorheriges Projekt: ${prevProject.data.title}`}>
            <span class="label">← Vorheriges Projekt</span>
            <span class="title">{prevProject.data.title}</span>
          </a>
          <a href={`/project-${nextProject.slug}`} class="project-nav-link next-link" aria-label={`Nächstes Projekt: ${nextProject.data.title}`}>
            <span class="label">Nächstes Projekt →</span>
            <span class="title">{nextProject.data.title}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="cta-band">
      <h2>Mehr Projekte entdecken</h2>
      <p>Schau dir weitere Case Studies an oder nimm direkt Kontakt auf.</p>
      <div class="hero__ctas">
        <a class="btn btn-primary" href="/projects">Alle Projekte</a>
        <a class="btn btn-outline" href="/contact">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Format compiled Markdown body to match legacy detail-block styles */
  .tina-content h2 {
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.8rem;
    color: var(--text-dark);
  }
  .tina-content h2:first-of-type {
    margin-top: 0;
  }
  .tina-content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }
  .tina-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.2rem;
    color: var(--text-muted);
    line-height: 1.6;
    list-style-type: disc;
  }
  .tina-content li {
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  /* Related Projects Styles */
  .project-navigation-wrap {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .project-navigation-wrap .nav-title {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 1.25rem;
  }
  .project-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 600px) {
    .project-nav-grid {
      grid-template-columns: 1fr;
    }
  }
  .project-nav-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-s);
    text-decoration: none;
    background: var(--card-bg);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .project-nav-link:hover {
    border-color: var(--magenta);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }
  .project-nav-link .label {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .project-nav-link .title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-dark);
    font-family: var(--font-display);
  }
  .project-nav-link.next-link {
    text-align: right;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const mermaidBlocks = document.querySelectorAll(".language-mermaid");
    if (mermaidBlocks.length > 0) {
      const script = document.createElement("script");
      script.src = "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js";
      script.onload = () => {
        mermaid.initialize({ startOnLoad: true, theme: 'neutral' });
        
        mermaidBlocks.forEach((block, index) => {
          const rawCode = block.textContent;
          const diagramContainer = document.createElement("div");
          diagramContainer.className = "mermaid";
          diagramContainer.id = `mermaid-${index}`;
          diagramContainer.textContent = rawCode;
          
          const preElement = block.closest("pre") || block;
          preElement.parentNode.replaceChild(diagramContainer, preElement);
        });
        
        mermaid.init(undefined, document.querySelectorAll(".mermaid"));
      };
      document.head.appendChild(script);
    }
  });
</script>
