{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@cep/platform-orchestrator": ["../platform-orchestrator/dist/src/index.d.ts"],
      "@cep/repository-gateway": ["../repository-gateway/dist/src/index.d.ts"],
      "@cep/provider-gateway": ["../provider-gateway/dist/src/index.d.ts"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
